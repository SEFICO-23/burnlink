# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://xxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOi...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...

# Auth
OPERATOR_EMAIL=you@example.com

# Facebook CAPI
FB_PIXEL_ID=1234567890
FB_CAPI_ACCESS_TOKEN=EAAB...
# Optional: leave unset in production. Use the test code from Events Manager while validating.
FB_TEST_EVENT_CODE=

# Telegram
# random 32+ hex chars, embedded in the webhook URL path
TG_WEBHOOK_SECRET=replace_with_openssl_rand_hex_32

# Vercel Cron
CRON_SECRET=replace_with_openssl_rand_hex_32

# Public app URL (no trailing slash)
APP_URL=https://burnlink.example.com
